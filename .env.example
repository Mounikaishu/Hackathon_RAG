# -----------------------------------------------------------------------------
# Placement Intelligence Agentic RAG - Environment Configuration Template
# Copy this file to '.env' and fill in your actual API keys.
# -----------------------------------------------------------------------------

# Groq API Configuration (Required)
GROQ_API_KEY=gsk_your_actual_groq_api_key_here

# Web Search Tool Configuration (Optional - DuckDuckGo fallback will be used if blank)
TAVILY_API_KEY=tvly-your_optional_tavily_key_here

# Directory Settings
CHROMA_DB_PATH=data/vector_db
PROCESSED_DIR=data/processed
CHARTS_DIR=data/processed/charts
RAW_DATA_DIR=data/raw

# Server Settings
HOST=127.0.0.1
PORT=8000
